# WordQuest 850 — Environment Variables
# Copy this file to .env and fill in your real keys.
# The EXPO_PUBLIC_ prefix makes variables visible in the client bundle (Expo SDK 49+).
# .env is gitignored; NEVER commit real keys.

# Unsplash API (https://unsplash.com/developers)
# Used by: src/services/imageService.ts → searchImages()
# Free tier: 50 req/hour (demo), unlimited after approval.
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pixabay API (https://pixabay.com/api/docs/)
# Used as fallback when Unsplash returns 401 / 429 / timeout.
# Free tier: 100 req/min.
EXPO_PUBLIC_PIXABAY_API_KEY=your_pixabay_api_key_here
